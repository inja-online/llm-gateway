# Any Anthropic Messages client (Claude SDK, some desktop tools)
export ANTHROPIC_BASE_URL=https://127.0.0.1:8787
export ANTHROPIC_API_KEY=local-dev
export ANTHROPIC_AUTH_TOKEN=local-dev
# Claude Code often uses model aliases via the gateway:
export ANTHROPIC_MODEL=sonnet
# export NODE_EXTRA_CA_CERTS=/path/to/examples/certs/localhost.pem
