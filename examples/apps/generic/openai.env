# Any OpenAI-compatible SDK / app
export OPENAI_BASE_URL=https://127.0.0.1:8787/v1
export OPENAI_API_KEY=local-dev
# Optional TLS trust for self-signed:
# export NODE_EXTRA_CA_CERTS=/path/to/examples/certs/localhost.pem
# export SSL_CERT_FILE=$NODE_EXTRA_CA_CERTS

# Example:
# curl -sk "$OPENAI_BASE_URL/chat/completions" \
#   -H "Authorization: Bearer $OPENAI_API_KEY" \
#   -H "Content-Type: application/json" \
#   -d '{"model":"gpt","messages":[{"role":"user","content":"hi"}]}'
