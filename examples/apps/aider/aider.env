# Aider → Inja LLM Gateway (ChatGPT / Claude / SuperGrok subscriptions)
# source this file, then run aider with an OpenAI-compatible model id.

export OPENAI_API_BASE=https://127.0.0.1:8787/v1
export OPENAI_API_KEY=local-dev
# Some Aider builds also read:
# export AIDER_OPENAI_API_BASE=$OPENAI_API_BASE
# export OPENAI_BASE_URL=$OPENAI_API_BASE

# TLS trust for self-signed (or use mkcert -install):
# export SSL_CERT_FILE=/path/to/examples/certs/localhost.pem
# export REQUESTS_CA_BUNDLE=$SSL_CERT_FILE
# export NODE_EXTRA_CA_CERTS=$SSL_CERT_FILE

# Examples:
#   aider --model openai/gpt
#   aider --model openai/sol
#   aider --model openai/grok-4.5
#   aider --model openai/sonnet
