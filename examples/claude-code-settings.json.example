{
  "$schema_note": "Merge one env block into ~/.claude/settings.json. Model aliases match examples/configs/* (updated 2026-07-23). Prefer the launcher for switching combos.",
  "env": {
    "ANTHROPIC_BASE_URL": "https://127.0.0.1:8787",
    "ANTHROPIC_API_KEY": "REPLACE_WITH_EDGE_OR_ANY_KEY",
    "ANTHROPIC_AUTH_TOKEN": "REPLACE_WITH_EDGE_OR_ANY_KEY",
    "ANTHROPIC_MODEL": "gpt",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "grok-4.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gpt",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "composer-2.5",
    "ANTHROPIC_SMALL_FAST_MODEL": "composer-2.5"
  },
  "_examples": {
    "gpt_only": {
      "ANTHROPIC_MODEL": "gpt",
      "ANTHROPIC_DEFAULT_OPUS_MODEL": "sol",
      "ANTHROPIC_DEFAULT_SONNET_MODEL": "terra",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL": "luna"
    },
    "grok_only": {
      "ANTHROPIC_MODEL": "grok-4.5",
      "ANTHROPIC_DEFAULT_OPUS_MODEL": "grok-4.5",
      "ANTHROPIC_DEFAULT_SONNET_MODEL": "grok-4.5",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL": "composer-2.5"
    },
    "gpt_plus_grok": {
      "ANTHROPIC_MODEL": "gpt",
      "ANTHROPIC_DEFAULT_OPUS_MODEL": "grok-4.5",
      "ANTHROPIC_DEFAULT_SONNET_MODEL": "gpt",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL": "composer-2.5"
    },
    "claude_only": {
      "ANTHROPIC_MODEL": "sonnet",
      "ANTHROPIC_DEFAULT_OPUS_MODEL": "opus",
      "ANTHROPIC_DEFAULT_SONNET_MODEL": "sonnet",
      "ANTHROPIC_DEFAULT_HAIKU_MODEL": "haiku"
    }
  },
  "_upstream_ids_2026_07": {
    "sonnet": "anthropic/claude-sonnet-5",
    "opus": "anthropic/claude-opus-4-8",
    "haiku": "anthropic/claude-haiku-4-5",
    "gpt": "chatgpt/gpt-5.6-terra",
    "sol": "chatgpt/gpt-5.6-sol",
    "luna": "chatgpt/gpt-5.6-luna",
    "grok-4.5": "xai/grok-4.5",
    "composer-2.5": "xai/grok-build-0.1"
  }
}
