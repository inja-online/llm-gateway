---
import { config } from "virtual:nimbus/config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "") || "";
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border bg-muted/30">
  <div class="mx-auto flex max-w-[90rem] flex-col gap-4 px-4 py-10 sm:flex-row sm:items-center sm:justify-between sm:px-6">
    <div>
      <p class="text-sm font-semibold text-foreground">{config.title}</p>
      <p class="mt-1 max-w-md text-sm text-muted-foreground">
        Multi-dialect LLM gateway — OpenAI · Anthropic · Gemini. AGPL-3.0.
      </p>
    </div>
    <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-muted-foreground">
      <a class="hover:text-foreground" href={`${base}/start/getting-started/`}>Docs</a>
      <a class="hover:text-foreground" href={`${base}/how-it-works/`}>How it works</a>
      <a class="hover:text-foreground" href={`${base}/project/license/`}>License</a>
      {
        config.github && (
          <a class="hover:text-foreground" href={config.github} target="_blank" rel="noopener noreferrer">
            GitHub
          </a>
        )
      }
    </div>
  </div>
  <div class="border-t border-border/70">
    <p class="mx-auto max-w-[90rem] px-4 py-4 text-xs text-muted-foreground sm:px-6">
      © {year} Inja. Built with <a class="underline-offset-2 hover:underline" href="https://nimbus-docs.com" target="_blank" rel="noopener noreferrer">Nimbus</a>.
    </p>
  </div>
</footer>
