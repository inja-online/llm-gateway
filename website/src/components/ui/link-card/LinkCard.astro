---
/**
 * LinkCard — link-styled card with title, optional description, and
 * trailing arrow that nudges on hover. Title shifts to primary on hover.
 *
 *   <LinkCard title="Get started" description="5-min intro" href="/start" />
 *   <LinkCard title="Title only" href="/x" />
 */
import { Icon } from "astro-icon/components";
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  title: string;
  description?: string;
  href: string;
}

const { title, description, href, class: className, ...attrs } = Astro.props;
---

<a
  href={href}
  class={cn(
    "group flex items-center justify-between gap-3 rounded-lg bg-card p-5 shadow-sm ring ring-border no-underline text-inherit transition-all hover:shadow-default hover:ring-border-strong",
    className,
  )}
  {...attrs}
>
  <div class="min-w-0">
    <h3 class="m-0 text-base font-semibold leading-snug text-foreground transition-colors group-hover:text-primary">{title}</h3>
    {description && <p class="mt-1 text-sm leading-normal text-muted-foreground">{description}</p>}
  </div>
  <Icon
    name="ph:caret-right"
    class="shrink-0 w-4 h-4 text-muted-foreground transition-all group-hover:translate-x-0.5 group-hover:text-primary"
  />
</a>
