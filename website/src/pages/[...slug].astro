---
import { getDocsStaticPaths, getDocsPageProps } from "nimbus-docs";
import DocsLayout from "@/layouts/DocsLayout.astro";

export const prerender = true;
export const getStaticPaths = getDocsStaticPaths;

const { entry, Content, headings } = await getDocsPageProps(Astro);
const data = entry.data;
const mode = data.mode ?? "doc";

// Custom mode pages render without docs chrome (landing-style).
if (mode === "custom") {
  // Handled by dedicated routes when needed; still render content wide.
}
const showSidebar = data.sidebar !== false && mode !== "custom";
const showToc = data.tableOfContents !== false && mode !== "custom";
const slug = entry.id === "index" ? "" : entry.id;
const base = import.meta.env.BASE_URL.replace(/\/$/, "") || "";
const markdownUrl = `${Astro.site?.toString().replace(/\/$/, "")}${base}/${slug ? slug + "/" : ""}index.md`.replace(
  /([^:]\/)\/+/g,
  "$1",
);
---

{
  mode === "custom" ? (
    <DocsLayout
      title={data.title}
      description={data.description}
      slug={entry.id}
      headings={headings}
      markdownUrl={markdownUrl}
      noindex={data.noindex}
      lastUpdated={data.lastUpdated}
      head={data.head}
      collection={entry.collection}
      entryId={entry.id}
      showSidebar={false}
      showToc={false}
      entry={entry}
    >
      <Content />
    </DocsLayout>
  ) : (
    <DocsLayout
      title={data.title}
      description={data.description}
      slug={entry.id}
      headings={headings}
      markdownUrl={markdownUrl}
      noindex={data.noindex}
      lastUpdated={data.lastUpdated}
      head={data.head}
      collection={entry.collection}
      entryId={entry.id}
      showSidebar={showSidebar}
      showToc={showToc}
      entry={entry}
    >
      <Content />
    </DocsLayout>
  )
}
