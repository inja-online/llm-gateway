---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { LinkButton } from "@/components/ui/link-button";
import { Badge } from "@/components/ui/badge";

const base = import.meta.env.BASE_URL.replace(/\/$/, "") || "";

const bullets = [
  "Route by model id, alias, or provider prefix",
  "Same-family passthrough; cross-family translation via canonical IR",
  "One usage event per request (JSONL / webhook)",
];

const links = [
  { href: `${base}/start/getting-started/`, label: "Getting started" },
  { href: `${base}/reference/compatibility-matrix/`, label: "Compatibility" },
  { href: `${base}/guides/claude-code/`, label: "Claude Code" },
];
---

<BaseLayout
  title="Inja LLM Gateway"
  description="Open-source multi-dialect LLM API gateway. One edge for OpenAI, Anthropic, and Gemini clients — route to any provider."
  current=""
>
  <main>
    <section class="relative overflow-hidden border-b border-border">
      <div
        class="pointer-events-none absolute inset-0 opacity-70"
        aria-hidden="true"
        style="background:
          radial-gradient(ellipse 80% 50% at 20% -10%, color-mix(in oklch, var(--nb-primary) 28%, transparent), transparent 55%),
          radial-gradient(ellipse 60% 40% at 90% 10%, color-mix(in oklch, var(--nb-info) 18%, transparent), transparent 50%);"
      ></div>
      <div class="relative mx-auto grid max-w-[90rem] gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:py-24">
        <div>
          <div class="mb-4 flex flex-wrap items-center gap-2">
            <Badge>Open source · AGPL-3.0</Badge>
            <Badge variant="info">OpenAI · Anthropic · Gemini</Badge>
          </div>
          <h1 class="max-w-xl text-4xl font-semibold tracking-tight text-foreground sm:text-5xl lg:text-[3.25rem] lg:leading-[1.08]">
            Inja LLM Gateway
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground">
            Multi-dialect LLM API gateway — one edge for OpenAI, Anthropic, and Gemini clients.
            Route to any provider without rewriting agents.
          </p>
          <ul class="mt-6 max-w-xl space-y-2.5 text-sm leading-relaxed text-foreground">
            {
              bullets.map((b) => (
                <li class="flex gap-2.5">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true" />
                  <span>{b}</span>
                </li>
              ))
            }
          </ul>
          <div class="mt-8 flex flex-wrap gap-3">
            <LinkButton href={`${base}/start/getting-started/`}>Get started</LinkButton>
            <LinkButton
              href="https://github.com/inja-online/llm-gateway"
              variant="outline"
              target="_blank"
              rel="noopener noreferrer"
            >
              View on GitHub
            </LinkButton>
          </div>
          <p class="mt-8 text-sm text-muted-foreground">
            Clients: OpenAI · Anthropic · Gemini
            <span class="mx-2 text-border">|</span>
            Kinds: <code class="font-mono text-xs">openai</code>
            · <code class="font-mono text-xs">openai_compat</code>
            · <code class="font-mono text-xs">anthropic</code>
            · <code class="font-mono text-xs">google</code>
          </p>
        </div>

        <div class="rounded-xl border border-border bg-card/80 shadow-lg ring-1 ring-border/60 backdrop-blur">
          <div class="flex items-center gap-2 border-b border-border px-4 py-3">
            <span class="h-2.5 w-2.5 rounded-full bg-danger/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-warning/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-success/80"></span>
            <span class="ml-auto font-mono text-xs text-muted-foreground">gateway.yaml</span>
          </div>
          <pre class="overflow-x-auto p-4 text-[0.8rem] leading-6 text-foreground sm:text-[0.85rem]"><code><span class="text-muted-foreground"># multi-provider edge</span>
providers:
  openai:
    kind: openai
    base_url: https://api.openai.com/v1
  anthropic:
    kind: anthropic
    base_url: https://api.anthropic.com/v1
  deepseek:
    kind: openai_compat
    base_url: https://api.deepseek.com

defaults:
  openai_dialect: openai
  anthropic_dialect: anthropic

aliases:
  fast: deepseek/deepseek-chat

hooks:
  jsonl:
    output: stdout</code></pre>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[90rem] px-4 py-12 sm:px-6">
      <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm" aria-label="Docs">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="font-medium text-primary no-underline hover:underline"
            >
              {l.label} →
            </a>
          ))
        }
      </nav>
    </section>
  </main>
</BaseLayout>
