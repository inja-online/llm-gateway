---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { LinkButton } from "@/components/ui/link-button";

const base = import.meta.env.BASE_URL.replace(/\/$/, "") || "";
---

<BaseLayout title="404 — Page not found" noindex current="404">
  <main class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-start gap-6 px-4 py-24 sm:px-6">
    <p class="font-mono text-sm text-muted-foreground">404</p>
    <h1 class="text-3xl font-semibold tracking-tight">Page not found</h1>
    <p class="text-muted-foreground">
      The page you are looking for does not exist or has moved. Try the docs index
      or the getting started guide.
    </p>
    <div class="flex flex-wrap gap-3">
      <LinkButton href={`${base}/`}>Back to home</LinkButton>
      <LinkButton href={`${base}/start/getting-started/`} variant="outline">
        Getting started
      </LinkButton>
    </div>
  </main>
</BaseLayout>
